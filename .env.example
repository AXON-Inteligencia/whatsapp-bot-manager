# Banco de dados principal usado para autenticação e usuários.
# No Vercel, estas variáveis são preenchidas pela integração Vercel Postgres/Neon.
POSTGRES_URL=your_postgres_url_here
POSTGRES_PRISMA_URL=your_postgres_prisma_url_here
POSTGRES_URL_NON_POOLING=your_postgres_non_pooling_url_here
POSTGRES_USER=your_postgres_user_here
POSTGRES_HOST=your_postgres_host_here
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DATABASE=your_postgres_database_here

# Segurança da autenticação.
# Use um valor longo e aleatório em produção.
JWT_SECRET=change_this_to_a_long_random_secret

# Admin inicial criado/atualizado automaticamente na primeira chamada de /api/auth.
ADMIN_EMAIL=admin@axonflow.local
ADMIN_PASSWORD=Axon@2026

# Compatibilidade com credenciais antigas documentadas no projeto.
# Defina como true se quiser criar apenas o ADMIN_EMAIL acima.
DISABLE_LEGACY_ADMIN_ALIASES=false

# Upstash Redis usado por filas, sessões/QR do WhatsApp e cache.
# Get these values from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=your_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_redis_rest_token_here

# URL Redis TCP para BullMQ/ioredis, quando disponível.
# Em Upstash, normalmente é a Redis URL começando com redis:// ou rediss://.
UPSTASH_REDIS_URL=your_redis_tcp_url_here

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
